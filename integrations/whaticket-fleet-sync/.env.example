# Whaticket (app.whaticket.com) — Settings > Tokens, crear un token con permiso read:contacts
WHATICKET_API_URL=https://api.whaticket.com/api/v1
WHATICKET_API_TOKEN=

# Twenty — Settings > Developers > API Keys
TWENTY_API_URL=https://TU-DOMINIO-DE-TWENTY/rest
TWENTY_API_KEY=

# Regex para identificar etiquetas "de camion" (rines con .5: R17.5, R19.5, R22.5, R24.5)
TRUCK_TAG_REGEX=R\d{2}\.5

# Nombre del campo custom (Text) creado en Twenty > Settings > Data Model > Person
# donde se guardan las medidas de camion detectadas para ese contacto
TWENTY_TRUCK_TAGS_FIELD_NAME=truckTireSizes

# Prefijo/codigo de pais por defecto para los telefonos que llegan de Whaticket
DEFAULT_PHONE_CALLING_CODE=+54
DEFAULT_PHONE_COUNTRY_CODE=AR
